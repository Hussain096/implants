{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "implants",
  "compatibility_date": "2026-06-17",
  "main": "./functions/_worker.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist/",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*"
    ]
  }
}
